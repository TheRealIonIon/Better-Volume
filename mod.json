{
	"geode": "5.6.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "nwo5.better_volume",
	"name": "Better Volume",
	"version": "v2.0.2-beta",
	"developers": [
		"Nwo5",
		"lyyako"
	],
	"description": "like the alpha mod kinda but cooler :3c",
	"tags": [
		"offline",
		"enhancement",
		"interface",
		"utility",
		"customization"
	],
	"links": {
		"source": "https://github.com/Nwo5-trg/Better-Volume",
		"community": "https://discord.gg/AeFeYWGUxZ"
	},
	"dependencies": {
		"geode.node-ids": ">=1.23.1",
		"nwo5.silly-api": ">=1.1.0"
	},
	"incompatibilities": {
		"alphalaneous.volume_input": ">=v1.0.0"
	},
	"settings": {
		"colored-bars": {
			"type": "bool",
			"name": "Colored Bars",
			"default": true
		},
		"music-color": {
			"type": "rgb",
			"name": "Music Color",
			"default": "#007dff"
		},
		"sfx-color": {
			"type": "rgb",
			"name": "SFX Color",
			"default": "#00ff7b"
		},
		"input-precision": {
			"type": "int",
			"name": "Input Precision",
			"min": 0,
			"max": 5,
			"default": 2
		},
		"mute-button": {
			"type": "bool",
			"name": "Mute Button",
			"default": true
		},
		"mute-button-right-pause": {
			"name": "Mute Button on Right (Pause)",
			"description": "Place the mute button on the right side of the slider in the Pause Menu.",
			"type": "bool",
			"default": false
		},
		"mute-button-right-options": {
			"name": "Mute Button on Right (Options)",
			"description": "Place the mute button on the right side of the slider in the Options Layer.",
			"type": "bool",
			"default": true
		},
		"music-text": {
			"type": "string",
			"name": "Music Text",
			"default": "Music:"
		},
		"sfx-text": {
			"type": "string",
			"name": "SFX Text",
			"default": "SFX:"
		}
	}
}
